#include "flying_fox-layouts.dtsi"
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <8>;
        map = <
            RC(0,0)
            RC(2,0) RC(2,1) RC(0,2)
            RC(2,2) RC(2,6) RC(2,3) RC(6,5) RC(6,2) RC(6,1)
            RC(7,1) RC(6,0) RC(6,3)
            RC(7,3)
            RC(0,1) RC(3,2) RC(0,6) RC(0,3) RC(2,4) RC(6,6) RC(7,5) RC(7,2) RC(5,1) RC(7,0)
            RC(3,1) RC(3,6) RC(3,3) RC(0,4) RC(7,6) RC(5,5) RC(5,2) RC(5,0)
            RC(1,3) RC(3,4) RC(3,5) RC(5,4) RC(5,6) RC(4,5)
            RC(1,4) RC(1,5) RC(4,4) RC(4,6)
        >;
    };
};

&physical_layout_flying_fox {
    transform = <&matrix_transform0>;
};

