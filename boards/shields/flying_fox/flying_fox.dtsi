#include "flying_fox-layouts.dtsi"
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <8>;
        map = <
            RC(1,0)
            RC(0,0) RC(0,1)
            RC(1,2)
            RC(0,2) RC(0,3) RC(0,4) RC(4,5) RC(4,1) RC(4,2)
            RC(5,2)
            RC(4,3) RC(4,0)
            RC(5,0) RC(1,1)
            RC(2,2)
            RC(1,3) RC(1,4)
            RC(0,5) RC(4,6)
            RC(5,5) RC(5,1)
            RC(6,2)
            RC(5,3)
            RC(2,1) RC(2,3) RC(2,4)
            RC(1,5) RC(5,6)
            RC(6,5) RC(6,1) RC(6,3)
            RC(3,4)
            RC(2,5) RC(2,6) RC(6,4) RC(6,6)
            RC(7,5) RC(3,5) RC(3,6) RC(7,4) RC(7,6)
        >;
    };
};

&physical_layout_flying_fox {
    transform = <&matrix_transform0>;
};

